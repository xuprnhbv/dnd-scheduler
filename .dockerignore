# Keep secrets and droplet runtime state out of the image — these live on the
# /data volume, not baked in. Mirrors .gitignore.
node_modules/
.wwebjs_auth/
.wwebjs_cache/
logs/
state.db
state.db-journal
state.db-wal
state.db-shm
config.json
service-account.json
.env
.DS_Store

# Repo cruft not needed at runtime.
.git/
.gitignore
.claude/
test/
*.md
